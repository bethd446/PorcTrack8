# PorcTrack Website — Variables d'environnement
# Copier ce fichier en .env pour le développement local

# Supabase (même projet que l'app — accès lecture publique uniquement)
VITE_SUPABASE_URL=https://jcritwravdwefwqwyjvk.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Déploiement VPS (utilisé par scripts/deploy.sh)
DEPLOY_HOST=your_vps_ip
