# Copy to .env.local and fill with your own secrets.
# .env.local is gitignored — never commit real credentials.

# Gemini AI (optional, injected by AI Studio at runtime)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Google Apps Script backend
# Get your deployment URL from: https://script.google.com/ → Deploy → Web app
VITE_GAS_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
VITE_GAS_TOKEN="YOUR_SHARED_SECRET"
