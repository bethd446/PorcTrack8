{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "metadata": {
    "name": "PorcTrack 8 — Agritech Dark",
    "version": "1.0.0",
    "description": "Design tokens Style Dictionary format. Source of truth for Ionic React integration."
  },
  "color": {
    "surface": {
      "bg-0":   { "value": "#0A0E0B", "type": "color", "comment": "App background · deepest layer" },
      "bg-1":   { "value": "#121714", "type": "color", "comment": "Card surface · 1 level up" },
      "bg-2":   { "value": "#1A211E", "type": "color", "comment": "Elevated surface · hover / emphasized cards" },
      "border": { "value": "#2A3239", "type": "color", "comment": "Hairline borders, dividers" }
    },
    "text": {
      "text-0": { "value": "#E8EFE8", "type": "color", "comment": "Primary text" },
      "text-1": { "value": "#9FB0A6", "type": "color", "comment": "Secondary text" },
      "text-2": { "value": "#6B7E74", "type": "color", "comment": "Tertiary / meta" }
    },
    "accent": {
      "accent":     { "value": "#10B981", "type": "color", "comment": "Emerald · primary brand" },
      "accent-fg":  { "value": "#04392D", "type": "color", "comment": "Foreground on accent backgrounds" },
      "accent-dim": { "value": "#065F46", "type": "color", "comment": "Accent hover / deeper tone" }
    },
    "signal": {
      "success": { "value": "#22C55E", "type": "color" },
      "warning": { "value": "#F59E0B", "type": "color" },
      "danger":  { "value": "#EF4444", "type": "color" },
      "info":    { "value": "#3B82F6", "type": "color" }
    },
    "semantic": {
      "amber": { "value": "#F4A261", "type": "color", "comment": "Alimentation, stocks" },
      "red":   { "value": "#EF4444", "type": "color", "comment": "Critique, rupture" },
      "blue":  { "value": "#60A5FA", "type": "color" },
      "gold":  { "value": "#D4A056", "type": "color", "comment": "Finances, rapport" },
      "coral": { "value": "#FB7185", "type": "color", "comment": "Pilotage, alertes sanitaires" },
      "teal":  { "value": "#2DD4BF", "type": "color", "comment": "Troupeau" },
      "cyan":  { "value": "#22D3EE", "type": "color", "comment": "Cycles" }
    },
    "tab-accent": {
      "cockpit":    { "value": "#10B981", "type": "color" },
      "troupeau":   { "value": "#2DD4BF", "type": "color" },
      "cycles":     { "value": "#22D3EE", "type": "color" },
      "ressources": { "value": "#F59E0B", "type": "color" },
      "pilotage":   { "value": "#FB7185", "type": "color" }
    }
  },
  "radius": {
    "sm":  { "value": "6px",  "type": "dimension" },
    "md":  { "value": "10px", "type": "dimension" },
    "lg":  { "value": "14px", "type": "dimension" },
    "xl":  { "value": "20px", "type": "dimension" },
    "2xl": { "value": "28px", "type": "dimension" }
  },
  "spacing": {
    "1":  { "value": "4px",  "type": "dimension" },
    "2":  { "value": "8px",  "type": "dimension" },
    "3":  { "value": "12px", "type": "dimension" },
    "4":  { "value": "16px", "type": "dimension" },
    "5":  { "value": "20px", "type": "dimension" },
    "6":  { "value": "24px", "type": "dimension" },
    "8":  { "value": "32px", "type": "dimension" },
    "10": { "value": "40px", "type": "dimension" },
    "12": { "value": "48px", "type": "dimension" }
  },
  "shadow": {
    "sm":          { "value": "0 1px 2px rgba(0,0,0,0.35)",  "type": "shadow" },
    "md":          { "value": "0 4px 12px rgba(0,0,0,0.40)", "type": "shadow" },
    "lg":          { "value": "0 12px 24px rgba(0,0,0,0.50)","type": "shadow" },
    "glow-accent": { "value": "0 0 0 1px rgba(16,185,129,0.25), 0 8px 24px rgba(16,185,129,0.15)", "type": "shadow" }
  },
  "motion": {
    "ease-spring":   { "value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "type": "cubicBezier" },
    "ease-gentle":   { "value": "cubic-bezier(0.22, 1, 0.36, 1)",    "type": "cubicBezier" },
    "ease-snappy":   { "value": "cubic-bezier(0.16, 1, 0.3, 1)",     "type": "cubicBezier" },
    "ease-out-expo": { "value": "cubic-bezier(0.23, 1, 0.32, 1)",    "type": "cubicBezier" }
  },
  "font-family": {
    "display": { "value": "BigShoulders, 'Big Shoulders Display', Impact, sans-serif",     "type": "fontFamily" },
    "body":    { "value": "InstrumentSans, -apple-system, system-ui, sans-serif",          "type": "fontFamily" },
    "values":  { "value": "BricolageGrotesque, InstrumentSans, sans-serif",                "type": "fontFamily" },
    "mono":    { "value": "DMMono, 'JetBrains Mono', ui-monospace, Menlo, monospace",      "type": "fontFamily" }
  },
  "font-size": {
    "display-xl": { "value": "44px", "type": "dimension" },
    "display-lg": { "value": "36px", "type": "dimension" },
    "display-md": { "value": "28px", "type": "dimension" },
    "display-sm": { "value": "22px", "type": "dimension" },
    "body-lg":    { "value": "15px", "type": "dimension" },
    "body-md":    { "value": "13px", "type": "dimension" },
    "body-sm":    { "value": "12px", "type": "dimension" },
    "label-xs":   { "value": "11px", "type": "dimension" }
  }
}
