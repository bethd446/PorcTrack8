Options -MultiViews
RewriteEngine On

# ── app.porctrack.tech → React SPA dans /app/ ─────────────────────────────

# 1. Images/fonts/manifest référencés en chemin absolu dans le JSX :
#    si le fichier n'existe pas à la racine, cherche dans /app/
RewriteCond %{HTTP_HOST} ^app\.porctrack\.tech$ [NC]
RewriteCond %{REQUEST_URI} ^/(images|fonts|manifest\.json) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ /app/$1 [L,QSA]

# 2. Catch-all SPA : toute route non-fichier → /app/index.html
RewriteCond %{HTTP_HOST} ^app\.porctrack\.tech$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /app/index.html [L]

# ── porctrack.tech → vitrine statique ────────────────────────────────────

# V29-FIX-INFRA P0 : assets/*.js inexistants → 404 strict, JAMAIS SPA fallback.
# Évite "MIME text/html" sur les chunks renommés au build, qui causaient
# "Failed to fetch dynamically imported module" et écrans blancs.
RewriteCond %{HTTP_HOST} ^(www\.)?porctrack\.tech$ [NC]
RewriteCond %{REQUEST_URI} ^/assets/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ - [R=404,L]

# Catch-all : chemins inconnus → index.html vitrine
RewriteCond %{HTTP_HOST} ^(www\.)?porctrack\.tech$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /index.html [L]

# ── Cache-Control PWA (fix 2026-05-14) ───────────────────────────────────
# Le service worker, le manifeste et le shell HTML ne doivent JAMAIS être
# mis en cache longue durée : sinon les utilisateurs restent bloqués sur une
# ancienne version de l'app même après un déploiement réussi (le SW gelé
# continue de servir les anciens bundles précachés). Bug constaté le
# 2026-05-14 : sw.js servi avec max-age=604800 par défaut Hostinger.
# Les assets dans /assets/ sont content-hashés → cache long assumé (défaut OK).
<IfModule mod_headers.c>
  <FilesMatch "^(service-worker\.js|sw\.js|registerSW\.js|workbox-.+\.js|push-handler\.js|index\.html|manifest\.webmanifest|manifest\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # ── Headers sécurité globaux (fix 2026-05-17) ────────────────────────────
  # Hostinger CDN ne renvoie aucun header de sécurité par défaut. Ces 5 en-têtes
  # constituent le minimum recommandé OWASP pour une SPA HTTPS :
  # - HSTS : force HTTPS 1 an, inclut sous-domaines, eligible preload list.
  # - X-Frame-Options : empêche le clickjacking via iframe tiers.
  # - X-Content-Type-Options : empêche le MIME-sniffing (XSS via fichiers fakes).
  # - Referrer-Policy : ne fuite l'URL complète qu'aux origines tierces.
  # - Permissions-Policy : désactive APIs sensibles non utilisées (camera/mic
  #   sont autorisées car app utilise Capacitor Camera pour photos cheptel).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(self), camera=(self), payment=(), usb=(), gyroscope=(), magnetometer=()"
</IfModule>
