{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5173",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && eslint src scripts --ignore-pattern '.claude/**' --ignore-pattern 'node_modules/**'",
    "lint:fix": "eslint src scripts --fix --ignore-pattern '.claude/**'",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "playwright test --config=tests/playwright.config.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:nav": "playwright test --config=tests/playwright.config.ts tests/e2e/navigation.spec.ts",
    "test:cheptel": "playwright test --config=tests/playwright.config.ts tests/e2e/cheptel.spec.ts",
    "test:forms": "playwright test --config=tests/playwright.config.ts tests/e2e/forms.spec.ts",
    "test:sheets": "playwright test --config=tests/playwright.config.ts tests/e2e/sheets-sync.spec.ts",
    "test:perf": "playwright test --config=tests/playwright.config.ts tests/e2e/performance.spec.ts",
    "test:ui": "playwright test --config=tests/playwright.config.ts --ui",
    "test:report": "playwright show-report tests/playwright-report",
    "test:all": "playwright test --config=tests/playwright.config.ts --reporter=html",
    "fonts:convert": "node scripts/convert-fonts-to-woff2.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/splash-screen": "6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@ionic/core": "^8.8.3",
    "@ionic/react": "^8.8.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "ionicons": "^8.0.13",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitest/ui": "^4.1.4",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "appium": "^3.3.1",
    "appium-uiautomator2-driver": "^7.1.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4",
    "wawoff2": "^2.0.1"
  }
}
