# Copy to .env.local and fill with your own secrets.
# .env.local is gitignored — never commit real credentials.

# Gemini AI (optional, injected by AI Studio at runtime)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Supabase backend (required)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Marius LLM (chatbot)
# WARNING: VITE_* vars are bundled into the client and visible to anyone.
# For production, proxy requests through a backend that holds the real key.
VITE_MARIUS_API_BASE="https://marius.ton-domaine.com"
VITE_MARIUS_API_KEY="changeme"

# V70 feature flag — false par défaut (legacy V44/V45)
VITE_V70_ENABLED=false

# V70 rollout progressif (réservé V71+, ignorer pour V70)
VITE_V70_ROLLOUT_PERCENT=0
