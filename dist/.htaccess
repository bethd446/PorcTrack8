Options -MultiViews
RewriteEngine On

# ── app.porctrack.tech → React SPA dans /app/ ─────────────────────────────

# 1. Images/fonts/manifest référencés en chemin absolu dans le JSX :
#    si le fichier n'existe pas à la racine, cherche dans /app/
RewriteCond %{HTTP_HOST} ^app\.porctrack\.tech$ [NC]
RewriteCond %{REQUEST_URI} ^/(images|fonts|manifest\.json) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ /app/$1 [L,QSA]

# 2. Catch-all SPA : toute route non-fichier → /app/index.html
RewriteCond %{HTTP_HOST} ^app\.porctrack\.tech$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /app/index.html [L]

# ── porctrack.tech → vitrine statique ────────────────────────────────────

# V29-FIX-INFRA P0 : assets/*.js inexistants → 404 strict, JAMAIS SPA fallback.
# Évite "MIME text/html" sur les chunks renommés au build, qui causaient
# "Failed to fetch dynamically imported module" et écrans blancs.
RewriteCond %{HTTP_HOST} ^(www\.)?porctrack\.tech$ [NC]
RewriteCond %{REQUEST_URI} ^/assets/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ - [R=404,L]

# Catch-all : chemins inconnus → index.html vitrine
RewriteCond %{HTTP_HOST} ^(www\.)?porctrack\.tech$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ /index.html [L]
